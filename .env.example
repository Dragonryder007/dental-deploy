## Backend SMTP (email confirmations)
## Copy this file to `.env` and fill values.
## Never commit your real `.env`.

# Gmail (recommended)
SMTP_SERVICE=gmail
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM="V Dental and Implant Center <yourgmail@gmail.com>"

# If you use custom SMTP instead of SMTP_SERVICE, comment out SMTP_SERVICE and use:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false

# Optional: JWT secret (admin auth)
# JWT_SECRET=change-me

# MySQL Configuration
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=smilevista

# Local only: auto-create MYSQL_DATABASE if missing (uncomment for first-time local setup).
# MYSQL_ALLOW_CREATE_DB=true

# ----------------------------
# AI Smile Preview (Google Gemini - free tier)
# ----------------------------
# 1. Get a free key at https://aistudio.google.com/app/apikey
# 2. Paste it below (no quotes). Restart the server after changing this value.
# 3. If GEMINI_API_KEY is empty, /api/smile-preview falls back to generic
#    recommendations and the UI shows "General suggestions" instead of
#    "Powered by Gemini".
GEMINI_API_KEY=
# Optional: override the default vision model (gemini-2.5-flash is free tier).
# GEMINI_MODEL=gemini-2.5-flash
# Optional: model for AI before/after image generation (Google AI Studio).
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# AI before/after images via Gemini — REQUIRES Pay-as-you-go in AI Studio (free tier limit = 0).
# 1. https://aistudio.google.com → Settings → Plan & billing → Pay-as-you-go
# 2. Create a NEW API key after billing is enabled → paste in GEMINI_API_KEY
# 3. Run: node scripts/check-gemini-billing.mjs  (must show "Billing looks OK")
# GEMINI_IMAGE_PREVIEW=true
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

